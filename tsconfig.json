{
  "compilerOptions": {
    "baseUrl": "./",
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["dom"],
    "module": "preserve",
    "outDir": "./types/raw",
    "rootDir": "./src/javascript",
    "skipLibCheck": true,
    "target": "esnext",
    "paths": {
      "~/*": ["./src/javascript/*"]
    },
    "plugins": [
      {
        "name": "gql.tada/ts-plugin",
        "schema": "./schema.graphql",
        "tadaOutputLocation": "./packages/gql/src/graphql-live.d.ts",
        "tadaTurboLocation": "./packages/gql/src/graphql-cache.d.ts"
      }
    ]
  },
  "include": ["src/javascript/**/*"]
}
